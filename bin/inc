#!/bin/bash
# inc - Incus instance manager
# Summary: Manages KaisarCode Incus containers and virtual machines.
# Author:  KaisarCode
# Website: https://kaisarcode.com
# License: https://www.gnu.org/licenses/gpl-3.0.html

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Print an informational message.
# @param $1 Message text.
# @return 0 on success.
log_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

# Print a success message.
# @param $1 Message text.
# @return 0 on success.
log_success() {
    echo -e "${GREEN}[OK]${NC} $1"
}

# Print a warning message.
# @param $1 Message text.
# @return 0 on success.
log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

# Print an error message.
# @param $1 Message text.
# @return 0 on success.
log_error() {
    echo -e "${RED}[ERROR]${NC} $1" >&2
}

# Print a skip message.
# @param $1 Message text.
# @return 0 on success.
log_skip() {
    echo -e "${YELLOW}[SKIP]${NC} $1"
}

# Prompt the user for yes or no confirmation.
# @param $1 Prompt message.
# @return 0 when confirmed, 1 otherwise.
confirm() {
    local message="$1"
    read -p "$message (y/n): " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        return 0
    else
        return 1
    fi
}

DEBIAN_VERSION="13"

# Provision one Incus instance.
# @param $1 Instance name.
# @param $2 User password.
# @param $3 Optional source instance name.
# @return 0 on success.
provision_instance() {
    local NAME=$1
    local PASSWORD=$2
    local SOURCE=${3:-""}
    local PRIMARY_USER
    
    PRIMARY_USER=$(id -un 1000 2>/dev/null || awk -F: '$3 == 1000 {print $1}' /etc/passwd)
    
    log_info "Provisioning instance '$NAME' (User: $PRIMARY_USER, mDNS: $NAME.local)..."
    
    sleep 5

    log_info "Setting hostname and timezone..."
    local HOST_TZ
    HOST_TZ=$(timedatectl show --property=Timezone --value 2>/dev/null || cat /etc/timezone 2>/dev/null || echo "Etc/UTC")
    
    incus exec "$NAME" -- hostnamectl set-hostname "$NAME"
    incus exec "$NAME" -- timedatectl set-timezone "$HOST_TZ" 2>/dev/null || true
    
    if [[ -n "$SOURCE" ]]; then
        incus exec "$NAME" -- sed -i "s/$SOURCE/$NAME/g" /etc/hosts 2>/dev/null || true
    fi
    incus exec "$NAME" -- sed -i "s/127.0.1.1.*/127.0.1.1 $NAME/g" /etc/hosts 2>/dev/null || true

    log_info "Configuring network interfaces (eth0/eth1)..."
    incus exec "$NAME" -- sh -c "cat <<EOF > /etc/netplan/50-cloud-init.yaml
network:
    version: 2
    ethernets:
        eth0:
            dhcp4: true
            dhcp4-overrides:
                route-metric: 200
            nameservers:
                addresses: [8.8.8.8, 1.1.1.1]
        eth1:
            dhcp4: true
            dhcp4-overrides:
                route-metric: 100
EOF"
    incus exec "$NAME" -- chmod 600 /etc/netplan/50-cloud-init.yaml
    incus exec "$NAME" -- netplan apply 2>/dev/null || true
    
    log_info "Creating user '$PRIMARY_USER'..."
    if ! incus exec "$NAME" -- id -u "$PRIMARY_USER" &>/dev/null; then
        incus exec "$NAME" -- useradd -m -s /bin/bash "$PRIMARY_USER" || { log_error "Failed to create user $PRIMARY_USER"; exit 1; }
    fi

    local PASS_HASH
    PASS_HASH=$(openssl passwd -6 "$PASSWORD")
    if incus exec "$NAME" -- id -u "$PRIMARY_USER" &>/dev/null; then
        incus exec "$NAME" -- usermod -p "$PASS_HASH" "$PRIMARY_USER"
        incus exec "$NAME" -- usermod -aG sudo "$PRIMARY_USER" 2>/dev/null || true
    else
        log_error "User '$PRIMARY_USER' was not found even after creation attempt."
        exit 1
    fi

    if incus exec "$NAME" -- id -u ubuntu &>/dev/null; then
        log_info "Removing default 'ubuntu' user..."
        incus exec "$NAME" -- userdel -f -r ubuntu 2>/dev/null || true
    fi

    log_info "Configuring sudo for $PRIMARY_USER..."
    incus exec "$NAME" -- sh -c "echo '$PRIMARY_USER ALL=(ALL) NOPASSWD:ALL' > /etc/sudoers.d/$PRIMARY_USER"
    incus exec "$NAME" -- chmod 440 /etc/sudoers.d/"$PRIMARY_USER"
    
    log_info "Installing packages (SSH, Avahi/mDNS)..."
    incus exec "$NAME" -- sh -c "apt update -qq && apt install -y -qq avahi-daemon openssh-server"

    log_info "Enabling SSH password authentication..."
    incus exec "$NAME" -- sed -i 's/^#PasswordAuthentication yes/PasswordAuthentication yes/' /etc/ssh/sshd_config
    incus exec "$NAME" -- sed -i 's/^PasswordAuthentication no/PasswordAuthentication yes/' /etc/ssh/sshd_config
    incus exec "$NAME" -- systemctl restart ssh 2>/dev/null || true
    incus exec "$NAME" -- systemctl restart avahi-daemon 2>/dev/null || true
    
    log_success "Provisioning complete for $NAME.local"
}

# Print command usage.
# @return 0 on success.
show_help() {
    echo -e "${BLUE}KCS Incus Manager${NC}"
    echo
    echo "Usage: $(basename "$0") <subcommand> [args...]"
    echo
    echo "Subcommands:"
    echo "  create <name> [--vm] [--no-lan] [--intf <interface>] [--autostart]"
    echo "  clone <origin> <new_name> [--no-lan] [--autostart]"
    echo "  list [instance_name]"
    echo "  load <instance_name> <snapshot_name>"
    echo "  remove <instance_name> [snapshot_name]"
    echo "  save <instance_name> <snapshot_name>"
    echo "  start <instance_name>"
    echo "  stop <instance_name>"
    echo "  export <instance_name> [filename.tar.gz]"
    echo "  import [new_name] <filename.tar.gz>"
    echo "  enter <instance_name> [command...]"
    echo "  snap [instance_name]"
    echo "  sync"
    echo
}

# Create an Incus instance.
# @param $@ Command arguments.
# @return 0 on success.
cmd_create() {
    INSTANCE_NAME=""
    SOURCE_NAME=""
    TYPE="container"
    USE_LAN=true
    INTF=""
    AUTOSTART=false

    while [[ $# -gt 0 ]]; do
        case $1 in
            --clone)
                SOURCE_NAME="$2"
                shift 2
                ;;
            --vm)
                TYPE="virtual-machine"
                shift
                ;;
            --lan)
                USE_LAN=true
                shift
                ;;
            --no-lan|--bridge)
                USE_LAN=false
                shift
                ;;
            --intf)
                INTF="$2"
                shift 2
                ;;
            --autostart)
                AUTOSTART=true
                shift
                ;;
            *)
                if [[ -z "$INSTANCE_NAME" ]]; then
                    INSTANCE_NAME="$1"
                else
                    log_error "Unknown argument: $1"
                    exit 1
                fi
                shift
                ;;
        esac
    done

    if [[ -z "$INSTANCE_NAME" ]]; then
        log_error "Usage: inc create <new_name> [--vm] [--no-lan] [--intf <interface>] [--autostart]"
        exit 1
    fi

    local PRIMARY_USER
    PRIMARY_USER=$(id -un 1000 2>/dev/null || awk -F: '$3 == 1000 {print $1}' /etc/passwd)

    echo -n -e "${BLUE}[QUERY]${NC} Set password for user '$PRIMARY_USER' (skip for default '$PRIMARY_USER'): "
    read -rs USER_PASSWORD
    echo
    [[ -z "$USER_PASSWORD" ]] && USER_PASSWORD="$PRIMARY_USER"

    if ! command -v incus >/dev/null 2>&1; then
        log_error "Incus is not installed. Run './profiles/base.sh' first."
        exit 1
    fi

    if [[ "$USE_LAN" == true ]] && [[ -z "$INTF" ]]; then
        INTF=$(ip route show default | awk '/default/ {print $5}' | head -n1)
        [[ -z "$INTF" ]] && { log_error "Could not auto-detect interface."; exit 1; }
    fi

    if [[ -n "$SOURCE_NAME" ]]; then
        log_info "Cloning $SOURCE_NAME into $INSTANCE_NAME..."
        incus copy "$SOURCE_NAME" "$INSTANCE_NAME"
        
        if [[ "$USE_LAN" == true ]]; then
            log_info "Configuring Dual-Network (Internal + LAN) for clone..."
            incus config device remove "$INSTANCE_NAME" eth0 2>/dev/null || true
            incus config device add "$INSTANCE_NAME" eth0 nic nictype=bridged parent="incusbr0" name=eth0

            incus config device remove "$INSTANCE_NAME" eth1 2>/dev/null || true
            incus config device add "$INSTANCE_NAME" eth1 nic nictype=macvlan parent="$INTF" name=eth1
        fi
        incus start "$INSTANCE_NAME"
        provision_instance "$INSTANCE_NAME" "$USER_PASSWORD" "$SOURCE_NAME"
    else
        log_info "Launching fresh Debian Server ${DEBIAN_VERSION} $TYPE: $INSTANCE_NAME..."
        LAUNCH_OPTS=()
        [[ "$TYPE" == "virtual-machine" ]] && LAUNCH_OPTS+=("--vm")
        
        if [[ "$USE_LAN" == true ]]; then
            log_info "Launching fresh instance with Dual-Network..."
            incus init "images:debian/${DEBIAN_VERSION}" "$INSTANCE_NAME" "${LAUNCH_OPTS[@]}"
            
            incus config device remove "$INSTANCE_NAME" eth0 2>/dev/null || true
            incus config device add "$INSTANCE_NAME" eth0 nic nictype=bridged parent="incusbr0" name=eth0

            incus config device remove "$INSTANCE_NAME" eth1 2>/dev/null || true
            incus config device add "$INSTANCE_NAME" eth1 nic nictype=macvlan parent="$INTF" name=eth1

            incus start "$INSTANCE_NAME"
        else
            incus launch "images:debian/${DEBIAN_VERSION}" "$INSTANCE_NAME" "${LAUNCH_OPTS[@]}"
        fi
        provision_instance "$INSTANCE_NAME" "$USER_PASSWORD"
    fi

    if [[ "$AUTOSTART" == true ]]; then
        log_info "Setting $INSTANCE_NAME to autostart on boot..."
        incus config set "$INSTANCE_NAME" boot.autostart true
    fi

    log_info "Enabling nesting for $INSTANCE_NAME..."
    incus config set "$INSTANCE_NAME" security.nesting true

    if lspci 2>/dev/null | grep -qi nvidia; then
        log_info "Ensuring GPU hardware mapping for $INSTANCE_NAME..."
        incus config device remove "$INSTANCE_NAME" gpu 2>/dev/null || true
        incus config device add "$INSTANCE_NAME" gpu gpu
        
        CUR_TYPE=$(incus info "$INSTANCE_NAME" | grep "Type:" | awk '{print $2}')
        if [[ "$CUR_TYPE" == "container" ]]; then
            incus config set "$INSTANCE_NAME" nvidia.runtime true
            incus config set "$INSTANCE_NAME" nvidia.driver.capabilities all
        fi
        log_success "GPU hardware ready on $INSTANCE_NAME"
    fi

    echo
    log_info "===================================================="
    log_success "Instance '$INSTANCE_NAME' is ready!"
    [[ "$AUTOSTART" == true ]] && log_info "Autostart: Enabled"
    [[ "$USE_LAN" == true ]] && log_info "IP on LAN: $(incus list "$INSTANCE_NAME" --format csv -c 4 | cut -d' ' -f1)"
    echo
    log_info "Management:"
    echo -e "   Enter:  ${BLUE}inc enter $INSTANCE_NAME${NC}"
    [[ -z "$SOURCE_NAME" ]] && log_info "Snapshot: incus snapshot create $INSTANCE_NAME <name>"
    log_info "===================================================="
}

# Clone an Incus instance.
# @param $1 Origin instance name.
# @param $2 New instance name.
# @param $@ Additional command arguments.
# @return 0 on success.
cmd_clone() {
    local origin="$1"
    local new_name="$2"
    shift 2 || true
    if [[ -z "$origin" ]] || [[ -z "$new_name" ]]; then
        log_error "Usage: inc clone <origin> <new_name> [--no-lan] [--autostart]"
        exit 1
    fi
    
    local PRIMARY_USER
    PRIMARY_USER=$(id -un 1000 2>/dev/null || awk -F: '$3 == 1000 {print $1}' /etc/passwd)

    echo -n -e "${BLUE}[QUERY]${NC} Set password for user '$PRIMARY_USER' (skip for default '$PRIMARY_USER'): "
    read -rs USER_PASSWORD
    echo
    [[ -z "$USER_PASSWORD" ]] && USER_PASSWORD="$PRIMARY_USER"

    cmd_create "$new_name" --clone "$origin" "$@"
}

# List Incus instances or snapshots.
# @param $1 Optional instance name.
# @return 0 on success.
cmd_list() {
    INSTANCE=$1
    if [[ -z "$INSTANCE" ]]; then
        log_info "Listing all Incus instances..."
        incus list --format table -c n,s,4,b
    else
        log_info "Listing snapshots for instance '$INSTANCE'..."
        if ! incus info "$INSTANCE" >/dev/null 2>&1; then
            log_error "Instance '$INSTANCE' not found."
            exit 1
        fi
        incus info "$INSTANCE" | sed -n '/Snapshots:/,$p'
    fi
}

# Restore an Incus instance snapshot.
# @param $1 Instance name.
# @param $2 Snapshot name.
# @return 0 on success.
cmd_load() {
    INSTANCE=$1
    SNAPSHOT=$2
    if [[ -z "$INSTANCE" ]] || [[ -z "$SNAPSHOT" ]]; then
        log_error "Usage: inc load <instance_name> <snapshot_name>"
        exit 1
    fi
    log_info "Stopping instance '$INSTANCE' before restore..."
    incus stop "$INSTANCE" --force 2>/dev/null || true
    log_info "Restoring instance '$INSTANCE' from snapshot '$SNAPSHOT'..."
    incus snapshot restore "$INSTANCE" "$SNAPSHOT"
    log_info "Starting instance '$INSTANCE'..."
    incus start "$INSTANCE"
    log_success "Instance '$INSTANCE' has been restored to state '$SNAPSHOT'."
}

# Remove an Incus instance or snapshot.
# @param $1 Instance name.
# @param $2 Optional snapshot name.
# @return 0 on success.
cmd_remove() {
    INSTANCE=$1
    SNAPSHOT=$2
    if [[ -z "$INSTANCE" ]]; then
        log_error "Usage: inc remove <instance_name> [snapshot_name]"
        exit 1
    fi

    if [[ -n "$SNAPSHOT" ]]; then
        if ! confirm "Are you sure you want to delete snapshot '$SNAPSHOT' from instance '$INSTANCE'?"; then
            log_warn "Deletion cancelled."
            exit 0
        fi
        log_info "Deleting snapshot '$SNAPSHOT' from instance '$INSTANCE'..."
        incus snapshot delete "$INSTANCE" "$SNAPSHOT"
        log_success "Snapshot '$SNAPSHOT' has been deleted."
    else
        echo -e "${RED}!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!${NC}"
        echo -e "${RED}WARNING: You are about to PERMANENTLY DELETE the instance '$INSTANCE'${NC}"
        echo -e "${RED}This will destroy all data and all snapshots associated with it.${NC}"
        echo -e "${RED}!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!${NC}"
        echo
        read -rp "Type 'YES' to confirm deletion of '$INSTANCE': " CONFIRM_STATUS
        echo

        if [[ "$CONFIRM_STATUS" != "YES" ]] && [[ "$CONFIRM_STATUS" != "yes" ]]; then
            log_error "Confirmation failed. You must type 'YES' or 'yes' to proceed."
            log_warn "Deletion cancelled."
            exit 1
        fi

        log_info "Stopping and deleting instance '$INSTANCE'..."
        incus stop "$INSTANCE" --force 2>/dev/null || true
        incus delete "$INSTANCE"
        log_success "Instance '$INSTANCE' has been completely removed."
    fi
}

# Save an Incus instance snapshot.
# @param $1 Instance name.
# @param $2 Snapshot name.
# @return 0 on success.
cmd_save() {
    INSTANCE=$1
    SNAPSHOT=$2
    if [[ -z "$INSTANCE" ]] || [[ -z "$SNAPSHOT" ]]; then
        log_error "Usage: inc save <instance_name> <snapshot_name>"
        exit 1
    fi
    log_info "Creating snapshot '$SNAPSHOT' for instance '$INSTANCE'..."
    incus snapshot create "$INSTANCE" "$SNAPSHOT"
    log_success "Snapshot '$SNAPSHOT' created successfully."
}

# Start an Incus instance.
# @param $1 Instance name.
# @return 0 on success.
cmd_start() {
    INSTANCE=$1
    if [[ -z "$INSTANCE" ]]; then
        log_error "Usage: inc start <instance_name>"
        exit 1
    fi
    log_info "Starting instance '$INSTANCE' and enabling autostart..."
    incus config set "$INSTANCE" boot.autostart true
    incus start "$INSTANCE" 2>/dev/null || log_skip "Instance '$INSTANCE' was already running."
    log_success "Instance '$INSTANCE' is now running and set to autostart on boot."
}

# Stop an Incus instance.
# @param $1 Instance name.
# @return 0 on success.
cmd_stop() {
    INSTANCE=$1
    if [[ -z "$INSTANCE" ]]; then
        log_error "Usage: inc stop <instance_name>"
        exit 1
    fi
    log_info "Stopping instance '$INSTANCE' and disabling autostart..."
    incus config set "$INSTANCE" boot.autostart false
    incus stop "$INSTANCE" 2>/dev/null || log_skip "Instance '$INSTANCE' was already stopped."
    log_success "Instance '$INSTANCE' is now stopped and will NOT autostart on boot."
}

# Export an Incus instance.
# @param $1 Instance name.
# @param $2 Optional output filename.
# @return 0 on success.
cmd_export() {
    INSTANCE=$1
    FILENAME=$2
    if [[ -z "$INSTANCE" ]]; then
        log_error "Usage: inc export <instance_name> [filename.tar.gz]"
        exit 1
    fi
    [[ -z "$FILENAME" ]] && FILENAME="${INSTANCE}.tar.gz"
    
    log_info "Exporting instance '$INSTANCE' to '$FILENAME'..."
    incus export "$INSTANCE" "$FILENAME" --optimized-storage
    log_success "Instance exported successfully to $FILENAME"
}

# Import an Incus instance.
# @param $@ Command arguments.
# @return 0 on success.
cmd_import() {
    if [[ $# -eq 1 ]]; then
        FILENAME=$1
        INSTANCE=""
    elif [[ $# -eq 2 ]]; then
        INSTANCE=$1
        FILENAME=$2
    else
        log_error "Usage: inc import [new_name] <filename.tar.gz>"
        exit 1
    fi
    
    if [[ ! -f "$FILENAME" ]]; then
        log_error "File not found: $FILENAME"
        exit 1
    fi

    log_info "Importing instance from '$FILENAME'..."
    if [[ -n "$INSTANCE" ]]; then
        incus import "$FILENAME" "$INSTANCE"
    else
        incus import "$FILENAME"
    fi
    log_success "Instance imported successfully."
}

# Replace quick snapshots.
# @param $1 Optional instance name.
# @return 0 on success.
cmd_snap() {
    INSTANCE=$1
    if [[ -z "$INSTANCE" ]]; then
        log_info "Replacing snapshot 'snap' for ALL instances..."
        local instances
        instances=$(incus list --format csv -c n)
        for name in $instances; do
            log_info "Snapping $name..."
            incus snapshot delete "$name" "snap" 2>/dev/null || true
            incus snapshot create "$name" "snap"
        done
        log_success "Quick snapshot 'snap' recreated for all instances."
        return
    fi
    log_info "Replacing quick snapshot 'snap' for instance '$INSTANCE'..."
    incus snapshot delete "$INSTANCE" "snap" 2>/dev/null || true
    incus snapshot create "$INSTANCE" "snap"
    log_success "Quick snapshot 'snap' recreated successfully."
}

# Synchronize managed instances.
# @return 0 on success.
cmd_sync() {
    log_info "Synchronizing managed instances..."
    local instances
    instances=$(incus list status=running --format csv -c n)
    
    if [[ -z "$instances" ]]; then
        log_warn "No running instances found."
        return
    fi

    local PRIMARY_USER
    PRIMARY_USER=$(id -un 1000 2>/dev/null || awk -F: '$3 == 1000 {print $1}' /etc/passwd)

    for name in $instances; do
        log_info "Updating $name..."
        
        if incus exec "$name" -- test -d "/home/$PRIMARY_USER/setup-debian"; then
            log_info "Pulling updates for setup-debian on $name..."
            incus exec "$name" -- sudo --login --user "$PRIMARY_USER" bash -c "git -C /home/$PRIMARY_USER/setup-debian pull" || log_error "Failed pull on $name"
        fi
    done
    log_success "All instances synchronized."
}

# Enter an Incus instance.
# @param $1 Instance name.
# @param $@ Optional command arguments.
# @return 0 on success.
cmd_enter() {
    INSTANCE=$1
    shift || true
    if [[ -z "$INSTANCE" ]]; then
        log_error "Usage: inc enter <instance_name> [command...]"
        exit 1
    fi
    
    local PRIMARY_USER
    PRIMARY_USER=$(id -un 1000 2>/dev/null || awk -F: '$3 == 1000 {print $1}' /etc/passwd)

    if [[ $# -eq 0 ]]; then
        log_info "Entering instance '$INSTANCE' as user '$PRIMARY_USER'..."
        incus exec "$INSTANCE" -- sudo --login --user "$PRIMARY_USER"
    else
        incus exec "$INSTANCE" -- sudo --login --user "$PRIMARY_USER" "$@"
    fi
}

# Run the command dispatcher.
# @param $@ Command arguments.
# @return 0 on success.
main() {
    local subcommand
    if [[ $# -eq 0 ]]; then
        show_help
        return 1
    fi
    subcommand="$1"
    shift
    case "$subcommand" in
        create) cmd_create "$@" ;;
        clone) cmd_clone "$@" ;;
        list) cmd_list "$@" ;;
        load) cmd_load "$@" ;;
        remove) cmd_remove "$@" ;;
        save) cmd_save "$@" ;;
        start) cmd_start "$@" ;;
        stop) cmd_stop "$@" ;;
        export) cmd_export "$@" ;;
        import) cmd_import "$@" ;;
        enter) cmd_enter "$@" ;;
        snap) cmd_snap "$@" ;;
        sync) cmd_sync "$@" ;;
        help|--help|-h) show_help ;;
        *) log_error "Unknown subcommand: $subcommand"; show_help; return 1 ;;
    esac
}

main "$@"
