#!/bin/bash
# iso - Generic Isolation Manager using Distrobox
# Summary: Manages isolated environments with segregated homes.
# Author:  KaisarCode
# Website: https://kaisarcode.com
# License: https://www.gnu.org/licenses/gpl-3.0.html

set -e

ISO_BASE_DIR="$HOME/.isolated"
ISO_DEFAULT_IMAGE="debian:trixie"

# Print usage.
iso_help() {
    echo "Usage: iso <command> [name] [args...]"
    echo
    echo "Commands:"
    echo "  create <name> [image]  Create an isolated environment"
    echo "  enter <name>           Enter the environment terminal"
    echo "  run <name> <cmd>       Run a command inside the environment"
    echo "  export <name> <app>    Export an app to the host desktop menu"
    echo "  list                   List isolated environments"
    echo "  destroy <name>         Remove the environment and its home"
    echo
}

# Create an environment.
iso_create() {
    local name="${1:-}"
    local image="${2:-$ISO_DEFAULT_IMAGE}"
    local home_dir="$ISO_BASE_DIR/$name"

    if [ -z "$name" ]; then
        echo "[ERROR] Name is required."
        return 1
    fi

    echo "[INFO] Creating isolated home at $home_dir..."
    mkdir -p "$home_dir"

    echo "[INFO] Creating Distrobox container '$name' using $image..."
    distrobox create --name "$name" --image "$image" --home "$home_dir" --yes
    echo "[OK] Environment '$name' created. Use 'iso enter $name' to start."
}

# Enter an environment.
iso_enter() {
    local name="${1:-}"
    if [ -z "$name" ]; then
        echo "[ERROR] Name is required."
        return 1
    fi
    distrobox enter "$name"
}

# Run a command inside.
iso_run() {
    local name="${1:-}"
    shift
    if [ -z "$name" ]; then
        echo "[ERROR] Name is required."
        return 1
    fi
    distrobox enter "$name" -- "$@"
}

# Export an app to the host.
iso_export() {
    local name="${1:-}"
    local app="${2:-}"
    if [ -z "$name" ] || [ -z "$app" ]; then
        echo "[ERROR] Name and App are required."
        return 1
    fi
    echo "[INFO] Exporting '$app' from '$name' to host menu..."
    distrobox enter "$name" -- distrobox-export --app "$app"
}

# List environments.
iso_list() {
    distrobox list
}

# Destroy an environment.
iso_destroy() {
    local name="${1:-}"
    local home_dir="$ISO_BASE_DIR/$name"

    if [ -z "$name" ]; then
        echo "[ERROR] Name is required."
        return 1
    fi

    echo "[WARN] Destroying environment '$name' and its home..."
    distrobox rm "$name" --force
    if [ -d "$home_dir" ]; then
        rm -rf "$home_dir"
    fi
    echo "[OK] Cleaned up."
}

# Dispatcher.
case "${1:-}" in
    create)  shift; iso_create "$@" ;;
    enter)   shift; iso_enter "$@" ;;
    run)     shift; iso_run "$@" ;;
    export)  shift; iso_export "$@" ;;
    list)    iso_list ;;
    destroy) shift; iso_destroy "$@" ;;
    *)       iso_help ;;
esac
